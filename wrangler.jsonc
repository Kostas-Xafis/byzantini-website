{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"main": "dist/_worker.js/_index.js",
	"name": "byzantini-website",
	"compatibility_date": "2025-11-17",
	"compatibility_flags": [
		"nodejs_compat", 
		"global_fetch_strictly_public"
	],
	"r2_buckets": [
		{
			"binding": "S3_BUCKET",
			"bucket_name": "byzantini-bucket",
			"preview_bucket_name": "bucket-dev",
		},
	],
	"observability": {
		"enabled": true,
	},
}
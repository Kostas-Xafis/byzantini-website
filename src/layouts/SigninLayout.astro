---
import Links from "@components/headers/Links.astro";
export interface Props {
	title: string;
	imageUrl?: string;
}

const { title, imageUrl } = Astro.props;
const logoUrl = imageUrl || "https://musicschool-metamorfosi.gr/logo.png";
---

<!doctype html>
<html lang="en">
	<head>
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<Links title={title} imageURL={logoUrl} />
		<script>
			import { applyDashboardTheme, resolveDashboardTheme } from "@utilities/theme";

			applyDashboardTheme(resolveDashboardTheme(), { persist: false });
		</script>
	</head>
	<body class="box-border h-[100dvh] p-0 grid bg-white grid-rows-[100dvh] overflow-hidden">
		<slot />
		<style is:inline>
			html {
				font-family: system-ui, sans-serif;
				height: 100vh;
			}
			p,
			a,
			button,
			h1,
			h2,
			h3 {
				color: #282828;
			}
			body {
				background: radial-gradient(ellipse at top, rgb(153 27 27 / 0.45), white);
				background-repeat: no-repeat;
			}
			html.dark p,
			html.dark a,
			html.dark button,
			html.dark h1,
			html.dark h2,
			html.dark h3,
			html.dark span {
				color: #f6f6f6;
			}
			html.dark body {
				background: radial-gradient(ellipse at top, rgb(127 29 29 / 0.5) -50%, rgb(12 12 12));
				background-repeat: no-repeat;
			}
			input:-webkit-autofill,
			input:-webkit-autofill:hover,
			input:-webkit-autofill:focus,
			textarea:-webkit-autofill,
			textarea:-webkit-autofill:hover,
			textarea:-webkit-autofill:focus,
			select:-webkit-autofill,
			select:-webkit-autofill:hover,
			select:-webkit-autofill:focus,
			input:autofill,
			textarea:autofill,
			select:autofill {
				-webkit-text-fill-color: #282828;
				caret-color: #282828;
				box-shadow: 0 0 0 1000px #ffffff inset !important;
				-webkit-box-shadow: 0 0 0 1000px #ffffff inset !important;
				transition: background-color 9999s ease-out;
			}
			html.dark input:-webkit-autofill,
			html.dark input:-webkit-autofill:hover,
			html.dark input:-webkit-autofill:focus,
			html.dark textarea:-webkit-autofill,
			html.dark textarea:-webkit-autofill:hover,
			html.dark textarea:-webkit-autofill:focus,
			html.dark select:-webkit-autofill,
			html.dark select:-webkit-autofill:hover,
			html.dark select:-webkit-autofill:focus,
			html.dark input:autofill,
			html.dark textarea:autofill,
			html.dark select:autofill {
				-webkit-text-fill-color: #f6f6f6;
				caret-color: #f6f6f6;
				box-shadow: 0 0 0 1000px #1a1a1a inset !important;
				-webkit-box-shadow: 0 0 0 1000px #1a1a1a inset !important;
			}
		</style>
	</body>
</html>
